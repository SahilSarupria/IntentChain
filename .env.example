# IntentChain v3.0 — Environment Variables

# ── LLM (intent parsing) ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── RPC endpoints ────────────────────────────────────────────────────────
# Sepolia keeps the original variable name for backwards compatibility.
# Every network works out-of-the-box on public RPCs; override any of these
# with your own Infura/Alchemy/QuickNode endpoint for production use.
INFURA_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
RPC_URL_SEPOLIA=
RPC_URL_ETHEREUM=
RPC_URL_POLYGON=
RPC_URL_ARBITRUM=
RPC_URL_OPTIMISM=
RPC_URL_BSC=

# ── Etherscan (unified v2 API — one key covers every supported chain) ───
# Free tier: https://etherscan.io/apis — enables /wallet/history
ETHERSCAN_API_KEY=

# ── Supply-chain / pharma traceability contract ──────────────────────────
# Deploy app/blockchain/contracts/SupplyChainTraceability.sol, then set the
# address here. Per-network vars take priority; the generic one is a
# fallback for single-chain setups.
SUPPLY_CHAIN_CONTRACT_ADDRESS=
SUPPLY_CHAIN_CONTRACT_ADDRESS_SEPOLIA=
SUPPLY_CHAIN_CONTRACT_ADDRESS_ETHEREUM=
SUPPLY_CHAIN_CONTRACT_ADDRESS_POLYGON=
